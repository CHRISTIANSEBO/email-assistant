# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Flask session secret — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-in-production

# Set to "production" to enable production guards (requires FLASK_SECRET_KEY)
FLASK_ENV=production

# OAuth callback URL — must match what is registered in Google Cloud Console
# For local dev, leave as default. For production, set to your public URL.
OAUTH_CALLBACK_URL=https://yourdomain.com/auth/callback

# Frontend origin — used to redirect after OAuth login
# For Docker (single-container), this is the same origin as the backend
FRONTEND_URL=https://yourdomain.com
